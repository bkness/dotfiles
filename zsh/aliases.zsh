# Aliases

# Git — core muscle-memory shortcuts
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gcm="git commit -m"
alias gca="git commit -a -m"
alias gp="git push"
alias gpl="git pull"
alias gl="git log --oneline --graph --decorate"
alias gd="git diff"
alias gds="git diff --staged"
alias gr="git restore"
alias grs="git restore --staged"
alias gss="git switch"

# GitHub dashboard
alias ghui="github_ui"

# Shell
alias c="clear"
alias ..="cd .."
alias cat="bat"
alias safe="zsh -f"
